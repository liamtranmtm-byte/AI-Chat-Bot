# ================== BAT BUOC de chay demo ==================
# API key cua Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# Key tu dat de bao ve trang xem lead (vd: /leads?key=day-la-key-cua-ban)
ADMIN_KEY=doi-thanh-key-bi-mat-cua-ban

# ================== Google Sheet (catalog + lead) ==================
# Doc catalog san pham va ghi lead truc tiep vao Google Sheet.
# Cach lam: tao Service Account tren Google Cloud Console -> tao key JSON ->
# dan TOAN BO noi dung file JSON vao bien duoi day (giu nguyen ca khoi { ... }).
# Nho SHARE quyen (Editor) Google Sheet cho email service account do.
GOOGLE_SERVICE_ACCOUNT_JSON=

# (Tuy chon) Neu khong dan nguyen JSON, co the tach rieng 2 bien nay thay the:
# GOOGLE_CLIENT_EMAIL=xxx@yyy.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n"

# ID cua Google Sheet chua catalog (lay tu URL: .../spreadsheets/d/<ID>/edit)
CATALOG_SHEET_ID=1RbHSYnAUKQXIY-2c1iw_NVSDclKUdCO2ss4HNr1RsgU
# (Tuy chon) Vung du lieu catalog, mac dinh A:H tren sheet dau tien
# CATALOG_RANGE=A:H
# (Tuy chon) So phut cache catalog, mac dinh 5
# CATALOG_CACHE_MINUTES=5

# (Tuy chon) Sheet/tab ghi lead. Mac dinh: cung Sheet catalog, tab ten "Leads"
# LEADS_SHEET_ID=
# LEADS_TAB=Leads

# ================== Anh san pham that (Google Drive) ==================
# Folder Drive chua anh san pham. Dat ten file theo ma san pham (vd RL001.jpg),
# server tu khop va phuc vu qua /img/<ID>. Nho SHARE folder cho service account
# (hoac "anyone with link: viewer"). ID folder lay tu URL: .../folders/<ID>
DRIVE_IMAGE_FOLDER_ID=
# (Tuy chon) So phut cache danh sach anh trong folder, mac dinh 5
# DRIVE_CACHE_MINUTES=5

# URL cong khai cua app, de tao link anh tuyet doi cho Zalo (vd https://ten-app.onrender.com)
# Render tu set RENDER_EXTERNAL_URL nen thuong KHONG can dien. Chi dien neu dung host khac.
# PUBLIC_BASE_URL=

# ================== Chan spam (tuy chon) ==================
# So tin toi da 1 user trong 1 cua so, va do dai cua so (giay). Mac dinh 10 tin / 60 giay
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_SEC=60

# ================== Tuy chon khac ==================
# Model Claude (mac dinh claude-sonnet-5)
# CLAUDE_MODEL=claude-sonnet-5
# Prompt goc ghi de hanh vi mac dinh cua bot (thuong de trong de dung prompt built-in)
# SYSTEM_PROMPT=

# Cong chay server (Render se tu gan PORT, khong can sua)
PORT=3000

# ================== Zalo OA (CHUA can cho demo) ==================
# De trong toan bo phan nay khi chi chay /demo. Chi dien khi trien khai Zalo that.
# Cong Zalo Developers (developers.zalo.me) sau khi tao App gan voi OA
ZALO_APP_ID=
ZALO_SECRET_KEY=
# Lay tu buoc OAuth lan dau (xem README) - se duoc code tu dong lam moi sau do
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=
