# Cong Zalo Developers (developers.zalo.me) sau khi tao App gan voi OA
ZALO_APP_ID=
ZALO_SECRET_KEY=

# Lay tu buoc OAuth lan dau (xem README) - se duoc code tu dong lam moi (refresh) sau do
ZALO_ACCESS_TOKEN=
ZALO_REFRESH_TOKEN=

# API key cua Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# Cong chay server (Render se tu gan PORT, khong can sua)
PORT=3000

# Key tu dat de bao ve trang xem lead (vd: /leads?key=day-la-key-cua-ban)
ADMIN_KEY=doi-thanh-key-bi-mat-cua-ban

# Prompt goc de dinh hinh tinh cach + nhiem vu cua bot (tuy chinh theo nhu cau)
SYSTEM_PROMPT="Ban la tro ly AI cham soc khach hang qua Zalo. Tra loi ngan gon, than thien, bang tieng Viet."
